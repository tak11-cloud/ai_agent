# GodDevX Configuration

# Application Settings
AGENT_DEBUG=false
AGENT_LOG_LEVEL=INFO

# LLM Configuration
AGENT_LLM__PROVIDER=ollama
AGENT_LLM__MODEL_NAME=mixtral:8x7b
AGENT_LLM__BASE_URL=http://localhost:11434
AGENT_LLM__MAX_TOKENS=2048
AGENT_LLM__TEMPERATURE=0.3

# Memory Configuration
AGENT_MEMORY__PROVIDER=chromadb
AGENT_MEMORY__PERSIST_DIRECTORY=./data/memory
AGENT_MEMORY__COLLECTION_NAME=agent_memory
AGENT_MEMORY__EMBEDDING_MODEL=sentence_transformers
AGENT_MEMORY__EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Executor Configuration
AGENT_EXECUTOR__USE_SANDBOX=true
AGENT_EXECUTOR__SANDBOX_TYPE=docker
AGENT_EXECUTOR__WORKING_DIRECTORY=/tmp/agent_workspace
AGENT_EXECUTOR__MAX_EXECUTION_TIME=300
AGENT_EXECUTOR__ALLOW_NETWORK=true
AGENT_EXECUTOR__ALLOW_SYSTEM_MODIFICATION=false

# Security Configuration
AGENT_SECURITY__ENABLE_COMMAND_FILTERING=true
AGENT_SECURITY__ENABLE_PATH_RESTRICTIONS=true
AGENT_SECURITY__MAX_FILE_SIZE=104857600  # 100MB

# UI Configuration
AGENT_UI__HOST=0.0.0.0
AGENT_UI__PORT=8000
AGENT_UI__ENABLE_CORS=true

# Data Directories
AGENT_DATA_DIRECTORY=./data
AGENT_LOGS_DIRECTORY=./logs
AGENT_TEMP_DIRECTORY=/tmp/agent_temp

# Feature Flags
AGENT_ENABLE_SELF_HEALING=true
AGENT_ENABLE_MEMORY_PERSISTENCE=true
AGENT_ENABLE_CONVERSATION_HISTORY=true
AGENT_ENABLE_CODE_ANALYSIS=true
AGENT_ENABLE_GIT_INTEGRATION=true

# Agent Configuration
AGENT_AGENTS__PLANNER__ENABLED=true
AGENT_AGENTS__CODER__ENABLED=true
AGENT_AGENTS__TERMINAL__ENABLED=true
AGENT_AGENTS__DEBUGGER__ENABLED=true
AGENT_AGENTS__GIT__ENABLED=true
AGENT_AGENTS__MEMORY__ENABLED=true
AGENT_AGENTS__SEARCH__ENABLED=true